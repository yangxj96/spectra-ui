{
    "name": "spectra-web",
    "author": {
        "name": "Jack Young",
        "email": "yangxj96@gmail.com",
        "url": "https://www.devops00.com/"
    },
    "license": "Apache-2.0",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "preview": "vite preview --host",
        "format": "prettier . --write --config ./.prettierrc.yml --log-level warn",
        "lint": "eslint . --cache",
        "lint:fix": "eslint . --fix --cache",
        "type-check": "vue-tsc --noEmit --composite false",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky",
        "prestart": "pnpm run format && pnpm run lint:fix && pnpm run type-check"
    },
    "lint-staged": {
        "*.{js,ts,vue}": "eslint --fix",
        "*.{js,ts,vue,css,scss,json,yml,md}": "prettier --write"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "subject-case": [
                0
            ],
            "header-max-length": [
                2,
                "always",
                120
            ],
            "body-max-line-length": [
                1,
                "always",
                200
            ],
            "footer-max-line-length": [
                1,
                "always",
                200
            ]
        }
    },
    "dependencies": {
        "@element-plus/icons-vue": "2.3.2",
        "@embedpdf/core": "2.14.3",
        "@embedpdf/engines": "2.14.3",
        "@embedpdf/plugin-document-manager": "2.14.3",
        "@embedpdf/plugin-render": "2.14.3",
        "@embedpdf/plugin-scroll": "2.14.3",
        "@embedpdf/plugin-viewport": "2.14.3",
        "@embedpdf/vue-pdf-viewer": "2.14.3",
        "@form-create/designer": "3.4.0",
        "@form-create/element-ui": "3.2.38",
        "@logicflow/core": "2.2.0",
        "@logicflow/extension": "2.2.0",
        "@tsparticles/slim": "3.9.1",
        "@tsparticles/vue3": "3.0.1",
        "@vueuse/core": "14.2.0",
        "@yangxj96/logicflow-plugin-flowable": "file:../logicflow-plugin-flowable",
        "echarts": "6.0.0",
        "element-plus": "2.13.2",
        "jsoneditor": "10.4.2",
        "p-queue": "9.1.0",
        "pinia": "3.0.4",
        "pinia-plugin-persistedstate": "4.7.1",
        "prismjs": "1.30.0",
        "qs": "6.14.2",
        "sass": "1.97.3",
        "suncalc-ts": "3.0.3",
        "vue": "3.5.28",
        "vue-echarts": "8.0.1",
        "vue-router": "5.0.2"
    },
    "devDependencies": {
        "@pinia/testing": "1.0.3",
        "@tsconfig/node24": "24.0.4",
        "@types/jsoneditor": "9.9.6",
        "@types/node": "24.10.4",
        "@types/prismjs": "1.26.5",
        "@types/qs": "6.14.0",
        "@vitejs/plugin-vue": "6.0.4",
        "@vitejs/plugin-vue-jsx": "5.1.4",
        "@commitlint/cli": "21.1.0",
        "@commitlint/config-conventional": "21.1.0",
        "@vue/eslint-config-typescript": "14.6.0",
        "@vue/test-utils": "2.4.6",
        "@vue/tsconfig": "0.8.1",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-vue": "10.7.0",
        "globals": "17.3.0",
        "happy-dom": "20.8.9",
        "husky": "9.1.7",
        "jiti": "2.6.1",
        "lint-staged": "16.2.7",
        "npm-run-all2": "8.0.4",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "vite": "8.0.11",
        "vite-plugin-compression2": "2.5.0",
        "vite-plugin-vue-devtools": "8.1.2",
        "vitest": "4.0.18",
        "vue-tsc": "3.2.4"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ],
    "pnpm": {
        "overrides": {
            "codemirror": "^6.0.2",
            "glob": "^13.0.6",
            "ini": "^7.0.0"
        }
    }
}
